# Database
DATABASE_URL="postgresql://user:password@localhost:5432/career_intel"

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# AI — Groq (free tier: console.groq.com — no credit card required)
GROQ_API_KEY=gsk_...

# AI — Google Gemini (optional, free tier: aistudio.google.com)
GOOGLE_AI_API_KEY=AIza...

# AI — Anthropic Claude (optional, requires paid credits)
ANTHROPIC_API_KEY=sk-ant-...

# PayFast (payfast.co.za — required for payments)
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase

# Admin
# Set to the email address that should have access to /api/admin/* routes
ADMIN_EMAIL=admin@yourdomain.com

# Job Alerts — Adzuna SA (free tier, 1 000 req/day — developer.adzuna.com)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="CareerIntel SA"
