{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/job-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/data-refresh-reminder",
      "schedule": "0 7 1 3,6,9,12 *"
    },
    {
      "path": "/api/cron/expire-plans",
      "schedule": "0 1 * * *"
    }
  ],
  "functions": {
    "app/api/chat/route.ts":             { "maxDuration": 30 },
    "app/api/cv/analyze/route.ts":       { "maxDuration": 60 },
    "app/api/career/paths/route.ts":     { "maxDuration": 30 },
    "app/api/skills/gap/route.ts":       { "maxDuration": 30 },
    "app/api/cron/job-alerts/route.ts":      { "maxDuration": 60 },
    "app/api/cron/weekly-digest/route.ts":          { "maxDuration": 60 },
    "app/api/cron/data-refresh-reminder/route.ts":  { "maxDuration": 30 },
    "app/api/cron/expire-plans/route.ts":           { "maxDuration": 30 }
  }
}
